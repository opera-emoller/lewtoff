/target
*.log
.DS_Store
/oracle-cache
/tests/fixtures/oracle-out/*.ogg
!/tests/fixtures/oracle-out/.keep

# Audio test corpus is too large/licence-heavy to commit. Each contributor
# stages their own files under /sounds and runs corpus_parity_44_stereo
# manually.
/sounds

# Ad-hoc debug binaries built from tools/debug-libvorbis-dump and
# tools/oracle-encoder. Only `harness` (and its .dSYM) is intentionally
# tracked because it's the canonical sine-440 dumper.
/tools/debug-libvorbis-dump/corpus_harness
/tools/debug-libvorbis-dump/corpus_harness.dSYM/
/tools/debug-libvorbis-dump/ramp_harness
/tools/debug-libvorbis-dump/ramp_harness.dSYM/
/tools/oracle-encoder/dump_window_tables
/tools/oracle-encoder/dump_window_tables.dSYM/

# oracle-encoder is the parity oracle used by tests/parity.rs. It must be
# rebuilt locally from the vendored libvorbis sources (run
# ./tools/oracle-encoder/build.sh after pulling). CI rebuilds it from the
# checked-out tree, so the host's macOS arm64 binary should not be
# committed alongside the Linux x86_64 version CI produces.
/tools/oracle-encoder/oracle-encoder
/tools/oracle-encoder/oracle-encoder.dSYM/
